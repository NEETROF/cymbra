{
  "uid": "cymbra-jobs",
  "title": "Cymbra — Job Queue",
  "tags": ["cymbra", "jobs"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Pending",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "jobs-postgres" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS value FROM jobs.pending"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "In-flight / waiting",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "jobs-postgres" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS value FROM jobs.inflight"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Dead-lettered",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "jobs-postgres" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT count(*) AS value FROM jobs.dead_letter"
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Per-channel depth & oldest age (seconds)",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "jobs-postgres" },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 4 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT channel_name, depth, EXTRACT(EPOCH FROM oldest_age)::int AS oldest_age_secs FROM jobs.channel_depth ORDER BY depth DESC"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent dead-letters",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "jobs-postgres" },
      "gridPos": { "h": 8, "w": 18, "x": 0, "y": 12 },
      "targets": [
        {
          "refId": "A",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT dead_lettered_at, name AS job_name, channel_name, attempts, last_error FROM jobs.dead_letter ORDER BY dead_lettered_at DESC LIMIT 50"
        }
      ]
    }
  ]
}
