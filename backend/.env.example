# Cymbra ID — backend configuration (task 1.7).
# Copy to `.env` for local dev. Values here match backend/docker-compose.yml.
# Loaded by the typed config layer (task 2.1); missing required keys fail fast.

# --- gRPC + HTTP listeners ---------------------------------------------------
CYMBRA_GRPC_ADDR=0.0.0.0:50051
CYMBRA_HTTP_ADDR=0.0.0.0:8081          # Axum surface: /.well-known/jwks.json, /healthz

# --- Postgres (one role per module; confined to its own schema) --------------
CYMBRA_AUTH_DATABASE_URL=postgres://auth_svc:auth_dev_pw@localhost:5432/cymbra_id
CYMBRA_USER_DATABASE_URL=postgres://user_svc:user_dev_pw@localhost:5432/cymbra_id
# worker_svc owns the shared `jobs` schema (queue + scheduler + dead-letter).
CYMBRA_WORKER_DATABASE_URL=postgres://worker_svc:worker_dev_pw@localhost:5432/cymbra_id

# --- Redis (sessions/refresh, rate-limit counters, email throttles) ----------
CYMBRA_REDIS_URL=redis://localhost:6379

# --- App audiences (one login per app; allow-list) ---------------------------
CYMBRA_ALLOWED_AUDIENCES=music,live

# --- Internal token signing (asymmetric; public keys served at JWKS) ---------
# EdDSA (Ed25519) keypair in PEM; the public key is served at the JWKS endpoint,
# `kid` identifies it. Generate: openssl genpkey -algorithm ed25519 -out priv.pem
#                                openssl pkey -in priv.pem -pubout -out pub.pem
CYMBRA_TOKEN_SIGNING_KEY_PEM=
CYMBRA_TOKEN_PUBLIC_KEY_PEM=
CYMBRA_TOKEN_SIGNING_KID=k1
CYMBRA_ACCESS_TOKEN_TTL=15m
CYMBRA_REFRESH_TOKEN_TTL=30d

# --- OIDC providers ----------------------------------------------------------
CYMBRA_GOOGLE_ISSUER=https://accounts.google.com
CYMBRA_GOOGLE_AUDIENCE=
CYMBRA_APPLE_ISSUER=https://appleid.apple.com
CYMBRA_APPLE_AUDIENCE=
# Apple client secret is a JWT signed with this .p8 key (<=6mo, regenerated).
CYMBRA_APPLE_P8_KEY_PEM=
CYMBRA_APPLE_TEAM_ID=
CYMBRA_APPLE_KEY_ID=
# Local dev OIDC issuer (mock-oauth2-server):
CYMBRA_DEV_OIDC_ISSUER=http://localhost:8080/default

# --- Local credential hardening ----------------------------------------------
CYMBRA_PASSWORD_MIN_LENGTH=12
CYMBRA_SIGNIN_MAX_ATTEMPTS=5
CYMBRA_SIGNIN_LOCKOUT=15m
CYMBRA_EMAIL_SEND_RATE=3/1h           # max verification/reset emails per window

# --- SMTP (verification / reset email) ---------------------------------------
CYMBRA_SMTP_URL=smtp://localhost:1025
CYMBRA_SMTP_FROM=no-reply@cymbra.dev

# --- Background worker (cymbra-worker; change: add-job-infrastructure) --------
# Required for any background work to run. Reads CYMBRA_WORKER_DATABASE_URL (the
# queue), CYMBRA_USER_DATABASE_URL (the reaper job's writes), and the SMTP vars
# above (the email job). Pickup is event-driven (LISTEN/NOTIFY); the operational
# tunable is concurrency, not a poll interval (design D7).
CYMBRA_WORKER_HTTP_ADDR=0.0.0.0:8082    # /healthz, /readyz
CYMBRA_WORKER_CONCURRENCY_MIN=1
CYMBRA_WORKER_CONCURRENCY_MAX=16
CYMBRA_WORKER_SCHEDULER_INTERVAL=30s    # how often jobs.schedules is evaluated
CYMBRA_WORKER_DLQ_SWEEP_INTERVAL=60s    # how often exhausted jobs are dead-lettered
# Grace before a handle-less account (abandoned onboarding) is reaped. The reaper
# is now a scheduled job (jobs.schedules row 'orphan_reap_hourly') run by the
# worker — its *cadence* is that row's cron; this only sets the grace window.
CYMBRA_ORPHAN_REAP_GRACE=24h

# --- OpenTelemetry -----------------------------------------------------------
CYMBRA_OTLP_ENDPOINT=http://localhost:4317
CYMBRA_OTLP_ENABLED=false             # disabled by default for offline/test runs
CYMBRA_TRACE_SAMPLE_RATIO=1.0
