// Local OAuth secrets for the iOS build — NEVER committed.
//
// Copy this file to `Secrets.xcconfig` (gitignored) and set your reversed Google
// client-id suffix: the part of GOOGLE_CLIENT_ID *before* `.apps.googleusercontent.com`.
//
//   GOOGLE_CLIENT_ID = 1234567890-abcdef.apps.googleusercontent.com
//   →  GOOGLE_OAUTH_CLIENT_SUFFIX = 1234567890-abcdef
//
// This overrides the inert default in Debug/Release.xcconfig so the OAuth callback
// URL scheme (com.googleusercontent.apps.<suffix>) resolves at build time. Pair it
// with `--dart-define=GOOGLE_CLIENT_ID=<full id>` when you run/build. iOS reuses the
// same iOS-type OAuth client as macOS when the bundle id matches (com.cymbra.music).
GOOGLE_OAUTH_CLIENT_SUFFIX = 1234567890-abcdef
