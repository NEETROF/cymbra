// Local OAuth secrets for the macOS build — NEVER committed.
//
// Copy this file to `Secrets.xcconfig` (gitignored) and set your reversed Google
// client-id suffix: the part of GOOGLE_CLIENT_ID *before* `.apps.googleusercontent.com`.
//
//   GOOGLE_CLIENT_ID = 1234567890-abcdef.apps.googleusercontent.com
//   →  GOOGLE_OAUTH_CLIENT_SUFFIX = 1234567890-abcdef
//
// This overrides the inert default in AppInfo.xcconfig so the OAuth callback URL
// scheme (com.googleusercontent.apps.<suffix>) resolves at build time. Pair it with
// `--dart-define=GOOGLE_CLIENT_ID=<full id>` when you run/build, and set the backend's
// CYMBRA_GOOGLE_AUDIENCE to the same full client ID. CI writes this file from the
// GOOGLE_CLIENT_ID secret.
GOOGLE_OAUTH_CLIENT_SUFFIX = 1234567890-abcdef
